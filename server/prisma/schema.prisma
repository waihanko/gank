generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  NORMAL_ADMIN
}

model Admin {
  id            String    @id @default(uuid())
  email         String    @unique
  password_hash String
  role          AdminRole @default(NORMAL_ADMIN)
  is_suspended  Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("admins")
}

model User {
  id                String   @id @default(uuid())
  email             String?  @unique
  username          String   @unique
  password_hash     String
  telegram_chat_id  String?  @unique @map("telegram_id")
  telegram_username String?   @unique
  telegram_display_name String?
  telegram_bio      String?
  mlbb_server_id    String
  mlbb_zone_id      String
  mlbb_ign          String
  mlbb_avatar_url   String?
  avatar_url        String?
  wins              Int      @default(0)
  losses            Int      @default(0)
  is_banned         Boolean  @default(false)
  ban_reason        String?
  last_telegram_change DateTime?
  last_mlbb_change     DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  wallet             Wallet?
  challenges         Match[]       @relation("Challenger")
  oppositions        Match[]       @relation("Opponent")
  won_matches        Match[]       @relation("Winner")
  lost_matches       Match[]       @relation("Loser")
  transactions       Transaction[]
  disputes_reported  Dispute[]     @relation("Reporter")
  disputes_resolved  Dispute[]     @relation("Resolver")
  screenshots        MatchScreenshot[]
  notifications      Notification[]
  battle_messages    BattleMessage[]  @relation("BattleMessages")

  @@unique([mlbb_server_id, mlbb_zone_id])
  @@map("users")
}

model Wallet {
  id               String        @id @default(uuid())
  user_id          String        @unique
  balance          Decimal       @default(0) @db.Decimal(12, 2)
  frozen_amount    Decimal       @default(0) @db.Decimal(12, 2)
  total_deposited  Decimal       @default(0) @db.Decimal(12, 2)
  total_withdrawn  Decimal       @default(0) @db.Decimal(12, 2)
  updated_at       DateTime      @updatedAt

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model TelegramGroup {
  id                   String   @id @default(uuid())
  chat_id              String   @unique
  invite_link          String
  title                String
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  messages             TelegramGroupMessage[]

  @@map("telegram_groups")
}

model TelegramGroupMessage {
  id         String   @id @default(uuid())
  group_id   String
  message    String
  sent_by    String
  created_at DateTime @default(now())

  group TelegramGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@map("telegram_group_messages")
}

model Match {
  id               String   @id @default(uuid())
  challenger_id    String
  opponent_id      String?
  stake_amount     Decimal  @db.Decimal(12, 2)
  total_pot        Decimal  @default(0) @db.Decimal(12, 2)
  commission       Decimal  @default(0) @db.Decimal(12, 2)
  status           String   @default("OPEN")
  room_id          String?
  match_code       String?
  winner_id        String?
  loser_id         String?
  challenger_ready Boolean  @default(false)
  opponent_ready   Boolean  @default(false)
  challenger_joined Boolean @default(false)
  opponent_joined   Boolean @default(false)
  challenger_invite_link String?
  opponent_invite_link   String?
  challenger_claim String?
  challenger_claim_at DateTime?
  opponent_claim   String?
  opponent_claim_at DateTime?
  screenshot_url   String?
  ocr_result       Json?
  ocr_verified     Boolean  @default(false)
  dispute_reason   String?
  resolved_by      String?
  started_at       DateTime?
  completed_at     DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  challenger   User          @relation("Challenger", fields: [challenger_id], references: [id])
  opponent     User?         @relation("Opponent", fields: [opponent_id], references: [id])
  winner       User?         @relation("Winner", fields: [winner_id], references: [id])
  loser        User?         @relation("Loser", fields: [loser_id], references: [id])
  logs         MatchLog[]
  screenshots  MatchScreenshot[]
  transactions Transaction[]
  disputes     Dispute[]
  revenue      PlatformRevenue[]
  battle_messages BattleMessage[]

  @@map("matches")
}

model Transaction {
  id           String   @id @default(uuid())
  wallet_id    String
  user_id      String
  type         String
  amount       Decimal  @db.Decimal(12, 2)
  match_id     String?
  description  String
  reference_id String?
  created_at   DateTime @default(now())

  wallet Wallet @relation(fields: [wallet_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])
  match  Match? @relation(fields: [match_id], references: [id])

  @@map("transactions")
}

model MatchLog {
  id                 String   @id @default(uuid())
  match_id           String
  sender_telegram_id String
  sender_username    String
  message_type       String   @default("text")
  content            String
  media_url          String?
  created_at         DateTime @default(now())

  match Match @relation(fields: [match_id], references: [id], onDelete: Cascade)

  @@map("match_logs")
}

model MatchScreenshot {
  id             String   @id @default(uuid())
  match_id       String
  uploaded_by    String
  file_url       String
  ocr_raw_text   String?
  ocr_victory    Boolean?
  ocr_battle_id  String?
  ocr_usernames  String[]
  ocr_confidence Decimal? @db.Decimal(5, 4)
  created_at     DateTime @default(now())

  match  Match @relation(fields: [match_id], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploaded_by], references: [id])

  @@map("match_screenshots")
}

model Dispute {
  id             String    @id @default(uuid())
  match_id       String
  reported_by_id String
  reason         String
  evidence_urls  String[]
  status         String    @default("PENDING")
  resolution     String?
  resolved_by_id String?
  resolved_at    DateTime?
  created_at     DateTime  @default(now())

  match       Match @relation(fields: [match_id], references: [id])
  reporter    User  @relation("Reporter", fields: [reported_by_id], references: [id])
  resolver    User? @relation("Resolver", fields: [resolved_by_id], references: [id])

  @@map("disputes")
}

model PlatformRevenue {
  id         String   @id @default(uuid())
  match_id   String
  amount     Decimal  @db.Decimal(12, 2)
  created_at DateTime @default(now())

  match Match @relation(fields: [match_id], references: [id])

  @@map("platform_revenue")
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@map("notifications")
}

model BattleMessage {
  id         String   @id @default(uuid())
  match_id   String
  sender_id  String?
  type       String   @default("text")   // text | system | ready | claim | screenshot
  content    String
  media_url  String?
  created_at DateTime @default(now())

  match  Match @relation(fields: [match_id], references: [id], onDelete: Cascade)
  sender User? @relation("BattleMessages", fields: [sender_id], references: [id])

  @@index([match_id, created_at])
  @@map("battle_messages")
}
